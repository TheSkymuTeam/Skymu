<Page
    x:Class="Skymu.Views.OptionPages.General.Sounds"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:classes="clr-namespace:Skymu.Classes"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:global="clr-namespace:Skymu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    xmlns:theming="clr-namespace:Skymu.Theming"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    DataContext="{StaticResource Lang}"
    FontFamily="Tahoma"
    FontSize="11"
    Style="{StaticResource Page}"
    mc:Ignorable="d"
    d:Background="#FFFFFF" >

    <StackPanel Margin="10,5,10,0" Orientation="Vertical">
        <TextBlock
            Padding="0,0,10,0"
            VerticalAlignment="Center"
            Foreground="Purple"
            Text="Example page" />

        <TextBlock
            Margin="50"
            Text="Oops, this page is not ready yet. Check out later!"/>

        <global:SliceControl
            Source="../../../Skyaeris/Assets/Universal/Home/footer.png" />
    </StackPanel>
</Page>
