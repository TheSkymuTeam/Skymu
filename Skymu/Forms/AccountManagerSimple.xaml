<Window
    x:Class="Skymu.Forms.AccountManagerSimple"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Account Manager"
	Width="450" Height="480"
    MinWidth="420" MinHeight="350"
	WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
	<Grid Margin="5">
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<ListBox
            x:Name="MainList"
            Grid.Row="0"
            HorizontalContentAlignment="Stretch"
            SelectedItem="{Binding SelectedAccount}"
            ItemsSource="{Binding Accounts}"
            d:ItemsSource="{d:SampleData ItemCount=15}" >
			<ListBox.ItemTemplate>
				<DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center" >
                            <TextBlock
                                Text="{Binding DisplayName}"
                                FontWeight="Bold" />
                            <TextBlock
                                Text="{Binding ProtocolName}"
                                FontSize="11"
                                Opacity="0.6" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal" >
                            <Button
                                Grid.Column="2"
                                Click="ToggleButton_Click"
                                Width="80" >
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="Disable"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Content" Value="Enable"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button
                                Grid.Column="3"
                                Margin="5,0,0,0"
                                Click="ALButton_Click"
                                Width="130" >
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="Disable auto login"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutoLoginEnabled}" Value="False">
                                                <Setter Property="Content" Value="Enable auto login"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button
                                Grid.Column="3"
                                Margin="5,0,0,0"
                                Content="Remove"
                                Click="RemoveButton_Click"
                                Width="80" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
        <StackPanel
            Margin="5,5,5,0"
            Grid.Row="1"
            Orientation="Horizontal"
            HorizontalAlignment="Right" >
            <Button
                Content="Add..."
                HorizontalAlignment="Right"
                Width="80"
                Click="AddButton_Click" />
            <Button
                Content="Close"
                HorizontalAlignment="Right"
                Margin="5,0,0,0"
                Width="80"
                Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
