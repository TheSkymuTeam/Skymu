<Window x:Class="Skymu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Skymu"
        xmlns:data="clr-namespace:MiddleMan;assembly=MiddleMan"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Title="Skype" Closing="MainWindow_Closing" Height="856" Width="1448" Deactivated="Window_Deactivated"
        StateChanged="Window_StateChanged" Activated="Window_Activated"
        Icon="/Skymu;component/UniversalResources/Icon/Skype.ico">
    <Window.Resources>
        <Style x:Key="WindowButtonStyle" TargetType="Image">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>
        <Style x:Key="LongIconStyle" TargetType="Image">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Width" Value="36" />
        </Style>
        <DataTemplate x:Key="ContactItemTemplate">
            <Grid Margin="1,1,0,5" Height="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Profile Picture -->

                <Border Grid.Column="0" Grid.RowSpan="3" BorderBrush="LightGray" 
        BorderThickness="1" 
        CornerRadius="0">
                    <Image Source="{Binding ProfilePicture, FallbackValue=/ResourcesLight/ProfilePictures/profile_man.png, TargetNullValue=/ResourcesLight/ProfilePictures/profile_man.png}" 
           Stretch="UniformToFill"/>
                </Border>

                <!-- Status Icon -->
                <local:ThreeSliceControl
Grid.Column="1"
Source="/ResourcesLight/MainSidebar/ms_SkypeStatus_Small.png"
ElementCount="21"
StackDirection="Horizontal"
DefaultIndex="2"
Margin="10,0,0,0"
HorizontalAlignment="Left"
HoverIndex="1"
PressedIndex="2"
Slice="false"
Width="14" Grid.Row="1"/>

                <!-- Contact Info -->
                
                    <TextBlock Grid.Column="2" Grid.Row="1" Margin="10,0,0,0" Text="{Binding Username}" 
                           FontSize="11"
                               FontFamily="Tahoma"
                           TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Status}" 
                               Grid.Column="2" Grid.Row="2" Margin="10,0,0,0"
                           FontSize="11"
    FontFamily="Tahoma"
                           Foreground="#999999"
                           TextTrimming="CharacterEllipsis"/>
                


            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid x:Name="TitleBar" Height="30" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="121" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="1" x:Name="CaptionButtons" Margin="0,0,5,0">
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="split" Margin="0" Width="26"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="minimize" Width="24"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="maximize" Width="24"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="close" Width="42"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
            </StackPanel>
            <Grid Grid.Column="0" x:Name="IconText">
                <TextBlock
                    x:Name="TitleShadow" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="50,7,0,0"
                    Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <BlurEffect
                            Radius="15.0"
                            KernelType="Gaussian" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock
                    x:Name="TitleShadow2" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="50,7,0,0"
                    Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <BlurEffect
                            Radius="20.0"
                            KernelType="Gaussian" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock
                    x:Name="TitleShadow3" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="50,7,0,0"
                    Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <BlurEffect
                            Radius="17.0"
                            KernelType="Gaussian" />
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock x:Name="TitleMain" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="Black"
                           VerticalAlignment="Top"
                           Margin="50,7,0,0"
                           Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            ShadowDepth="0"
                            Direction="330"
                            Color="White"
                            Opacity="1"
                            BlurRadius="20" />
                    </TextBlock.Effect>
                </TextBlock>
                <Image Style="{StaticResource LongIconStyle}" x:Name="tbli" MouseLeftButtonUp="tbli_Click"
                       Margin="8,0,0,0" />
            </Grid>
        </Grid>
        <Grid x:Name="WindowArea" Background="#d4e2f2" Margin="8,30,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="21" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Menu Grid.Row="0" Height="20" Background="Transparent" FontFamily="Tahoma" Name="menu1"
                  VerticalAlignment="Top" FontSize="11">
                <MenuItem Header="_Skype">
                    <MenuItem Header="Online Status" />
                    <Separator />
                    <MenuItem Header="Privacy..." />
                    <MenuItem Header="Account..." />
                    <MenuItem Header="Buy Skype Credit..." />
                    <Separator />
                    <MenuItem Header="Change Password..." />
                    <MenuItem Header="Sign Out" />
                    <MenuItem Header="Switch User" />
                    <MenuItem Header="Close" />
                </MenuItem>
                <MenuItem Header="C_ontacts">
                    <MenuItem Header="Add a Contact..." />
                    <MenuItem Header="New Contact..." />
                    <MenuItem Header="Search for Skype Users..." />
                    <MenuItem Header="Import Contacts..." />
                    <MenuItem Header="Create New Group..." />
                    <Separator />
                    <MenuItem Header="Contact Categories" />
                    <MenuItem Header="Show Outlook Contacts" />
                    <Separator />
                    <MenuItem Header="Remove from Contacts" />
                </MenuItem>
                <MenuItem Header="Co_nversation" />
                <MenuItem Header="_Call" />
                <MenuItem Header="_View" />
                <MenuItem Header="_Tools">
                    <MenuItem Header="Apps" Click="mn_Apps" />
                    <Separator />
                    <MenuItem Header="Change Language" Click="mn_Language" />
                    <Separator />
                    <MenuItem Header="Accessibility" Click="mn_Accessibility" />
                    <MenuItem Header="Share Skype with a Friend..." Click="mn_ShareWithFriend" />
                    <Separator />
                    <MenuItem Header="Skype Wi-Fi Access..." Click="mn_SkypeWifi" />
                    <Separator />
                    <MenuItem Header="Options..." Click="mn_Options" />
                </MenuItem>
                <MenuItem Header="_Help" />
            </Menu>
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#adc3dc" />
            <Border Grid.Row="1" BorderBrush="Transparent" BorderThickness="4">
                <Grid x:Name="ContentArea">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" x:Name="Sidebar">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="22" />
                        </Grid.RowDefinitions>
                        <Grid x:Name="SidebarStatus" Grid.Row="0" VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />

                            </Grid.RowDefinitions>
                            <local:ThreeSliceControl
                                Grid.Row="0"
                                x:Name="StatusBox"
                                Source="/ResourcesLight/MainSidebar/ms_Status_Top.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="1"
                                PressedIndex="2"
                                HorizontalAlignment="Stretch" 
                                Text="thegamingkart"
                                TextStartPositionX="43"
                                TextFont="Arial"
                                TextWeight="Bold"
                                TextSize="13"
                                TextColor="#333333"/>
                            <local:ThreeSliceControl
                                Grid.Row="0"
                                Source="/ResourcesLight/MainSidebar/ms_SkypeStatus.png"
                                ElementCount="21"
                                StackDirection="Horizontal"
                                DefaultIndex="2"
                                HorizontalAlignment="Left"
                                Margin="9,0,0,0"
                                HoverIndex="1"
                                PressedIndex="2"
                                Slice="false"
                                Width="16"/>
                            <Image Grid.Row="0" Source="ResourcesLight/MainSidebar/ms_Status_DropArrow.png"
                                   Width="12"
                                   Height="16"
                                   HorizontalAlignment="Left"
                                   Margin="25,0,0,0"/>
                            <local:ThreeSliceControl
                                x:Name="SkypeCreditBox"
                                Grid.Row="1"
                                Source="/ResourcesLight/MainSidebar/ms_Status_Bottom.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="1"
                                PressedIndex="2"
                                Text="$ 0.00 - No subscription"
                                TextStartPositionX="34"
                                TextFont="Tahoma"
                                TextSize="11"
                                TextColor="#333333"
                                HorizontalAlignment="Stretch" />
                            <Image Grid.Row="1" Source="ResourcesLight/MainSidebar/ms_Credit.png"
                                   Width="16"
                                   Height="16"
                                   HorizontalAlignment="Left"
                                   Margin="9,0,0,0"/>
                        </Grid>
                        <Grid x:Name="SidebarTabs" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <local:ThreeSliceControl
                                x:Name="btnContacts"
                                Grid.Column="0"
                                Source="/ResourcesLight/MainSidebar/ms_Contacts.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="-1"
                                PressedIndex="2"
                                Text="Contacts"
                                TextStartPositionX="30"
                                TextFont="Arial"
                                TextWeight="Bold"
                                TextSize="13"
                                TextColor="#333333"

                                HorizontalAlignment="Stretch" />
                            <local:ThreeSliceControl
                                x:Name="btnRecents"
                                Grid.Column="1"
                                Source="/ResourcesLight/MainSidebar/ms_Recents.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="-1"
                                PressedIndex="2"
                                Text="Recent"
                                TextStartPositionX="30"
                                TextFont="Arial"
                                TextWeight="Bold"
                                TextSize="13"
                                TextColor="#333333"
                                HorizontalAlignment="Stretch" />

                        </Grid>
                        <Border Grid.Row="3" Background="White" BorderBrush="#b4c0ce"
                                BorderThickness="1,0,1,0">
                            <Grid x:Name="ContactsArea">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="31" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="0" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="1" />
                                </Grid.RowDefinitions>
                                <local:ThreeSliceControl
                                    Grid.Row="0"
                                    Source="/ResourcesLight/MainSidebar/ms_SearchBox.png"
                                    ElementCount="2"
                                    StackDirection="Vertical"
                                    DefaultIndex="1"
                                    HoverIndex="1"
                                    PressedIndex="0"
                                    Text="Search"
                                    TextStartPositionX="33"
                                    TextFont="Tahoma"
                                    TextSize="11"
                                    TextColor="#999999"
                                    HorizontalAlignment="Stretch" />
                                <Rectangle Grid.Row="1" Height="1" Fill="#b4c0ce" />
                                <ListBox x:Name="ContactsList"  
         Grid.Row="2"        
         BorderThickness="0"
         ItemTemplate="{StaticResource ContactItemTemplate}"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <Rectangle Grid.Row="4" Height="1" Fill="#b4c0ce" />
                                <local:ThreeSliceControl
                                    Grid.Row="5"
                                    Source="/ResourcesLight/MainSidebar/ms_CallPhones.png"
                                    ElementCount="5"
                                    StackDirection="Vertical"
                                    DefaultIndex="0"
                                    HoverIndex="1"
                                    PressedIndex="2"
                                    Text="Call phones"
                                    TextStartPositionX="32"
                                    TextFont="Arial"
                                    TextWeight="Bold"
                                    TextSize="13"
                                    TextColor="#333333"
                                    HorizontalAlignment="Stretch" />
                                <Rectangle Grid.Row="6" Height="1" Fill="#b4c0ce" />
                            </Grid>
                        </Border>
                        <Border
                            Grid.Row="4"
                            Background="#ebeef1"
                            BorderBrush="#B4C0CE"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <TextBlock Text="Skymu Beta. All rights reserved."
                                       x:Name="GlobalUserCount"
                                       Margin="6,0,0,0"
                                       FontFamily="Tahoma"
                                       FontSize="11"
                                       Foreground="#999999"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                    </Grid>
                    <Rectangle x:Name="SkypeSplitter" Grid.Column="1" MouseLeftButtonDown="SkypeSplitter_Press"
                               MouseMove="SkypeSplitter_MouseMove" Fill="Transparent" Cursor="SizeWE" />
                    <Grid Grid.Column="2" x:Name="MessageArea" Background="#ebf3fc" />
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>