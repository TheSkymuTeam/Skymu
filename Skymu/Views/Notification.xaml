<Window Style="{StaticResource Window}" x:Class="Skymu.Views.Notification" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:global="clr-namespace:Skymu"  xmlns:converters="clr-namespace:Skymu.Converters" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Notification" xmlns:properties="clr-namespace:Skymu.Properties" SizeToContent="Height" Width="240" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True" ShowActivated="False" FontFamily="Tahoma" FontSize="11">
    <Window.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator"/>
        <converters:SharedAssetPathGenerator x:Key="SharedAssetPathGenerator"/>
    </Window.Resources>
    <Grid>
        <global:SliceControl x:Name="bubble" Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Notifications/bubble-orange.png'}" SliceMode="2" HorizontalAlignment="Stretch" StackDirection="Vertical" ElementCount="1" DefaultIndex="0"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Margin="5,0,0,0" Stretch="Fill"
    Width="33"
    Height="15" Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Branding/skype-notif.png'}" VerticalAlignment="Center" HorizontalAlignment="Left">
            </Image>
            <Border Grid.Row="1" Padding="8,7">
                <StackPanel x:Name="MessagesContainer" Orientation="Vertical">
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>