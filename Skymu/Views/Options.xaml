<Window
    x:Class="Skymu.Views.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:global="clr-namespace:Skymu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:Skymu.Properties"
    Width="708"
    Height="600"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    DataContext="{StaticResource Lang}"
    FontFamily="Tahoma"
    FontSize="11"
    ResizeMode="CanMinimize"
    Style="{StaticResource Window}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Title>
        <MultiBinding StringFormat="{}{0}™ {1}">
            <Binding Path="[sMAINMENU_SKYPE]" Source="{StaticResource Lang}" />
            <Binding Path="[sF_OPTIONS_CAPTION]" Source="{StaticResource Lang}" />
        </MultiBinding>
    </Window.Title>
    <Window.Resources>
        <converters:StringToDoubleConverter x:Key="StringToDoubleConverter" />
        <converters:SharedAssetPathGenerator x:Key="SharedAssetPathGenerator" />
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
    </Window.Resources>
    <Grid Background="#d4e2f2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="195" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Grid Margin="9,9,9,0">
                <global:SliceControl
                    HorizontalAlignment="Stretch"
                    DefaultIndex="1"
                    ElementCount="5"
                    HoverIndex="-1"
                    IsHitTestVisible="False"
                    PressedIndex="-1"
                    Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Options/header.png'}"
                    StackDirection="Vertical"
                    Text="{Binding [sF_OPTIONS_PAGE_DEBUG]}"
                    TextColor="#666666"
                    TextFont="Tahoma"
                    TextLeftMargin="38"
                    TextSize="11" />
                <Image
                    Height="24"
                    Margin="8,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Options/action.png'}" />
            </Grid>
            <ListBox
                Margin="9,0,9,0"
                BorderBrush="#26000000"
                BorderThickness="1,0,1,1">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="Foreground" Value="#FF6E6E73" />
                        <Setter Property="Height" Value="38" />
                        <Setter Property="Padding" Value="10,1,8,1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        Name="Border"
                                        Padding="{TemplateBinding Padding}"
                                        Background="Transparent"
                                        BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Image
                                                Height="24"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Source="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                                            <ContentPresenter
                                                Margin="6,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#84c0fc" />
                                            <Setter Property="Foreground" Value="#666666" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>
                <ListBoxItem
                    Content="Skymu Customization"
                    IsSelected="True"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Options/personalize.png'}" />
            </ListBox>
        </StackPanel>
        <Grid Grid.Column="1" Margin="-4,9,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <global:SliceControl
                Grid.Row="0"
                Margin="0,0,9,0"
                HorizontalAlignment="Stretch"
                DefaultIndex="1"
                ElementCount="5"
                HoverIndex="-1"
                IsHitTestVisible="False"
                PressedIndex="-1"
                Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Options/header.png'}"
                StackDirection="Vertical" />
            <StackPanel
                Grid.Row="0"
                Margin="9,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Grid.Row="0"
                    FontFamily="Tahoma"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="#666666"
                    Text="Skymu Customization:" />
                <TextBlock
                    Grid.Row="0"
                    Margin="7,0"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="#666666"
                    Text="Modify the way Skymu looks, feels, and behaves" />
            </StackPanel>
            <Border
                x:Name="OptionCategoryContainer"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,0,9,45"
                Background="White"
                BorderBrush="#26000000"
                BorderThickness="1,0,1,1">
                <ScrollViewer>
                    <StackPanel Margin="15,15,15,15" Orientation="Vertical">
                        <StackPanel Margin="0,5" Orientation="Horizontal">
                            <TextBlock
                                Padding="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Universal branding name" />
                            <TextBox
                                x:Name="SC_BrandingNameBox"
                                Width="250"
                                FontFamily="Tahoma"
                                Text="{Binding Source={x:Static properties:Settings.Default}, Path=BrandingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,5" Orientation="Horizontal">
                            <TextBlock
                                Padding="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="{Binding [sF_USERINFO_LABEL_LANGUAGE]}" />
                            <ComboBox
                                Width="250"
                                DisplayMemberPath="Key"
                                ItemsSource="{Binding Languages}"
                                SelectedValue="{Binding Source={x:Static properties:Settings.Default}, Path=Language, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>
                        <StackPanel Margin="0,5" Orientation="Horizontal">
                            <TextBlock
                                Padding="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Main window frame" />
                            <ComboBox Width="250" SelectedIndex="{Binding Source={x:Static properties:Settings.Default}, Path=WindowFrame, Mode=TwoWay}">
                                <ComboBoxItem Content="Skype Aero" />
                                <ComboBoxItem Content="Skype Basic" />
                                <ComboBoxItem Content="Use the system window frame" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,5" Orientation="Horizontal">
                            <TextBlock
                                Padding="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Application theme (experimental)" />
                            <ComboBox
                                Width="250"
                                SelectedValue="{Binding Source={x:Static properties:Settings.Default}, Path=ThemeRoot, Mode=TwoWay}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem Content="Light" Tag="Light" />
                                <ComboBoxItem Content="Dark" Tag="Dark" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,5" Orientation="Horizontal">
                            <TextBlock
                                Padding="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Base theme (scrollbar, buttons, etc)" />
                            <ComboBox
                                Width="250"
                                SelectedValue="{Binding Source={x:Static properties:Settings.Default}, Path=PresFrame, Mode=TwoWay}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem Content="Windows XP" Tag="Luna.NormalColor" />
                                <ComboBoxItem Content="Windows XP (Olive)" Tag="Luna.Homestead" />
                                <ComboBoxItem Content="Windows XP (Silver)" Tag="Luna.Metallic" />
                                <ComboBoxItem Content="Windows XP Media Center" Tag="Royale.NormalColor" />
                                <ComboBoxItem Content="Windows Vista" Tag="Aero.NormalColor" />
                                <ComboBoxItem Content="Windows 8" Tag="Aero2.NormalColor" />
                                <ComboBoxItem Content="Windows 8 Basic" Tag="AeroLite.NormalColor" />
                                <ComboBoxItem Content="Windows Classic" Tag="Classic" />
                            </ComboBox>
                        </StackPanel>

                        <CheckBox
                            Margin="0,5"
                            Content="Enable auto-login for accounts with valid credentials saved"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=AutoLogin, Mode=TwoWay}" />
                        <StackPanel Margin="0,5" Orientation="Horizontal">
                            <TextBlock
                                Padding="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Emoji animation speed (FPS)" />
                            <TextBox
                                Width="40"
                                FontFamily="Tahoma"
                                Text="{Binding Source={x:Static properties:Settings.Default}, Path=EmojiFps, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource StringToDoubleConverter}}" />
                        </StackPanel>
                        <CheckBox
                            Margin="0,5"
                            Content="Display a notification when you recieve a message"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=EnableNotifications, Mode=TwoWay}" />
                        <CheckBox
                            Margin="0,5"
                            Content="Make notifications blue instead of the accurate orange"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=AccurateNotifications, Mode=TwoWay}" />
                        <CheckBox
                            Margin="0,5"
                            Content="Dynamically resize sidebar tabs based on selection (accurate)"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=DynamicSidebarTabs, Mode=TwoWay}" />

                        <CheckBox
                            Margin="0,5"
                            Content="Use GDI+ text rendering pipeline on Windows"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=UseClearType, Mode=TwoWay}" />
                        <CheckBox Margin="0,5" IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=FallbackFillColors, Mode=TwoWay}">
                            <CheckBox.Content>
                                <TextBlock TextWrapping="Wrap">
                                    Use Skype fallback window colors, and do not switch the color scheme based on window activation state.
                                    Useful for users with visual motion sickness or if you think the colors are ugly.
                                </TextBlock>
                            </CheckBox.Content>
                        </CheckBox>
                        <CheckBox
                            Margin="0,5"
                            Content="Enable the 'Skype Home' feature (experimental, may use 20-60 MB of additional RAM)"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=EnableSkypeHome, Mode=TwoWay}" />
                        <CheckBox
                            Margin="0,5"
                            Content="{Binding [sF_USERENTRY_CB_START_SKYPE]}"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=StartOnStartup, Mode=TwoWay}" />
                        <CheckBox
                            Margin="0,5"
                            Content="Retain original versions of edited and deleted messages (MessageLogger)"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=MessageLogger, Mode=TwoWay}" />
                        <CheckBox
                            Margin="0,5"
                            Content="Do not reveal my username and display name in Skymu's connected user statistics"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=Anonymize, Mode=TwoWay}" />
                        <CheckBox
                            MaxWidth="450"
                            Margin="0,5"
                            HorizontalAlignment="Left"
                            IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=DisablePingbacks, Mode=TwoWay}">
                            <CheckBox.Content>
                                <TextBlock TextWrapping="Wrap">
                                    Completely block communication with the Skymu server (warning: not recommended,
                                    doing this breaks features in the Skymu client!)
                                </TextBlock>
                            </CheckBox.Content>
                        </CheckBox>

                        <!--<StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Use port" VerticalAlignment="Center" Width="80"/>
                            <TextBox Width="80"/>
                            <TextBlock Text="for incoming connections" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <CheckBox Content="Use port 80 and 443 for additional incoming connections" IsChecked="True" Margin="0,5"/>

                        <ComboBox Width="250" Margin="0,10">
                            <ComboBoxItem Content="Automatic proxy detection" IsSelected="True"/>
                            <ComboBoxItem Content="HTTPS proxy"/>
                            <ComboBoxItem Content="SOCKS proxy"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Host" Width="80"/>
                            <TextBox Width="150"/>
                            <TextBlock Text="Port" Margin="10,0,0,0" Width="40"/>
                            <TextBox Width="80"/>
                        </StackPanel>

                        <CheckBox Content="Enable proxy authentication" Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Username" Width="80"/>
                            <TextBox Width="150"/>
                            <TextBlock Text="Password" Margin="10,0,0,0" Width="60"/>
                            <TextBox Width="150"/>
                        </StackPanel>-->
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Height="23"
                Margin="0,0,9,11"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                RenderTransformOrigin="0.362,-3.031">
                <Button
                    Height="23"
                    MinWidth="73"
                    Margin="0,0,10,0"
                    Padding="12,0"
                    Click="SaveButtonClick"
                    Content="{Binding [sF_OPTIONS_BUTTON_SAVE]}"
                    FontSize="11" />
                <Button
                    Height="23"
                    MinWidth="73"
                    Margin="0,0,10,0"
                    Padding="12,0"
                    Click="RestartButtonClick"
                    Content="Save and restart"
                    FontSize="11" />
                <Button
                    Height="23"
                    MinWidth="73"
                    Margin="0,0,10,0"
                    Padding="12,0"
                    Click="ResetButtonClick"
                    Content="{Binding [sF_OPTIONS_BTN_RESET]}"
                    FontSize="11" />
                <Button
                    Height="23"
                    MinWidth="73"
                    Padding="12,0"
                    Click="CancelButtonClick"
                    Content="{Binding [sF_OPTIONS_BUTTON_CANCEL]}"
                    FontSize="11" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>