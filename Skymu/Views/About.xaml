<Window
    x:Class="Skymu.Views.About"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:global="clr-namespace:Skymu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    Title="About"
    Width="501"
    Height="454"
    AllowsTransparency="True"
    Style="{StaticResource Window}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <converters:SharedAssetPathGenerator x:Key="SharedAssetPathGenerator" />
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='backgrounds/about.png'}" Stretch="Uniform" />
    </Window.Background>
    <StackPanel>
        <Image
            Height="108"
            Margin="0,115,0,3"
            Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Branding/logo-about.png'}" />
        <TextBlock
            Margin="0,1,9,0"
            HorizontalAlignment="Center"
            FontFamily="Arial"
            FontSize="20"
            FontWeight="Bold"
            Foreground="{StaticResource Text.HighContrast}"
            Text="Take another breath" />
        <TextBlock
            x:Name="BuildVersion"
            Margin="0,3,9,-6"
            HorizontalAlignment="Center"
            FontFamily="Arial"
            FontSize="13"
            FontWeight="Bold"
            Foreground="#555555">
            <TextBlock.Text>
                <MultiBinding StringFormat="v{0} {1}">
                    <Binding Source="{x:Static global:Universal.BuildVersion}" />
                    <Binding Source="{x:Static global:Universal.BuildName}" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
        <TextBlock
            Width="390"
            Margin="0,23,10,0"
            HorizontalAlignment="Center"
            FontFamily="Tahoma"
            FontSize="11"
            Foreground="#363636"
            LineHeight="16"
            Text="Open-source software: http://skymu.app/legal/licenses/standard.txt&#x0a;You can find our repository over at GitHub listed under the Skymu name.&#x0a;Skymu is not associated with Skype or Microsoft. However, Skymu contains assets created by Skype Limited and employed under fair use."
            TextAlignment="Center"
            TextWrapping="Wrap" />
        <TextBlock
            Width="390"
            Margin="0,16,10,0"
            HorizontalAlignment="Center"
            FontFamily="Tahoma"
            FontSize="11"
            Foreground="#363636"
            LineHeight="16"
            Text="Skymu is a multi-protocol chat client that faithfully recreates the user interface of older Skype versions. As far as we know, no comparable product exists, and the Skype branding has been completely retired. You are running the .NET Framework build of Skymu, which is compatible with Windows Vista and above."
            TextAlignment="Center"
            TextWrapping="Wrap" />
    </StackPanel>
</Window>