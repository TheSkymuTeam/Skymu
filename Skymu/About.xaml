<Window x:Class="Skymu.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Skymu"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="About" Height="454" Width="501">
    <Window.Background>
        <ImageBrush ImageSource="/ResourcesLight/Backgrounds/aboutBackground.png" Stretch="Uniform" /> 
    </Window.Background>
    <StackPanel>
        <Image Source="/UniversalResources/Branding/skymu-about-logo.png" Height="111" Margin="0,115,0,0" />
        <TextBlock Text="Skymu, a Skype-like instant messenger" HorizontalAlignment="Center" FontFamily="Tahoma" FontWeight="Bold" FontSize="11" Margin="0,18,16,0"/>
        <TextBlock Text="FOSS software, licensed under (Placeholder)&#x0a;You can find our repository over at GitHub under the Skymu name.&#x0a;Skymu is not associated with Skype nor Microsoft, all assets are owned by Microsoft and Skype Limited." LineHeight="16" Width="390" TextWrapping="Wrap" Foreground="#363636" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,23,13,0" FontFamily="Tahoma" FontSize="11" />
        <TextBlock Text="Warning: If you have paid for this software with real currency, please ask for a chargeback from your bank! Skymu is free and forever will be free, please report the URL with the paid content to support@hubaxe.fr. We will handle the situation and take it down." LineHeight="16" Width="390" TextWrapping="Wrap" Foreground="#363636" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,16,13,0" FontFamily="Tahoma" FontSize="11"/>
    </StackPanel>
</Window>