<Page x:Class="Skymu.Skyaeris.CallScreen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:global="clr-namespace:Skymu"
      xmlns:converters="clr-namespace:Skymu.Converters"
      mc:Ignorable="d"
      Title="CallScreen"
      FontFamily="Arial" FontSize="15.5"  Width="1100" Height="700" >
    <Page.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator"/>
    </Page.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Assets/Universal/Call Screen/background.png"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Image Width="169"  Source="Assets/Universal/Call Screen/logo.png" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Vertical">
                <Image Height="160" Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, 
                    Source='Profile Pictures/thegamingkart.jpg'}"
                    RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Margin="0,18,0,5" Foreground="White" FontWeight="Bold" TextAlignment="Center" 
                           Text="thegamingkart"/>
                <TextBlock Foreground="White" FontSize="11" TextAlignment="Center" 
                           Text="calling"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/connection_anim.png" 
                                 StackDirection="Vertical"
                                 AnimationFps="30"
                                 ElementCount="10"
                                 IsAnimation="True"
                                 DefaultIndex="0"
                                 HoverIndex="1" 
                                 SliceMode="0"
                                 VerticalAlignment="Bottom"
                                 Margin="0,50"/>
                <Image Height="160"  Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Profile Pictures/sensei_wu.jpg'}" RenderOptions.BitmapScalingMode="HighQuality" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" x:Name="actionbar" VerticalAlignment="Bottom"  HorizontalAlignment="Center" Margin="0,0,0,16" >
            <Grid.ColumnDefinitions>
                <!-- You might be wondering why Column 1 is 156px and Column 2 is 164px,
                and why both aren't 160px for an equally aligned UI. The answer to this
                question is: Ask the Skype designers, it's their fault. If I fixed this
                visual bug, it wouldn't look accurate, and this is why the columns are 
                going to remain misaligned. -->
                <ColumnDefinition Width="156"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="164"/>
            </Grid.ColumnDefinitions>
            <global:SliceControl Grid.ColumnSpan="3" Width="Auto" Source="Assets/Universal/Call Screen/pill.png" />
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="24,0,0,0">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_sidebar_expand.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_chat_inactive.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="8,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_mic.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="4,0"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_dialpad.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="4,0"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_add.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="4,0"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_hangup.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="4,0"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0" HorizontalAlignment="Right">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_connection_4.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="0,0,8,0"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_screen_expand.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
