<Page
    x:Class="Skymu.Skyaeris.CallScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:global="clr-namespace:Skymu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CallScreen"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FontFamily="Arial"
    FontSize="15.5"
    SizeChanged="Resized"
    Style="{StaticResource Page}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <Style x:Key="ActionButtonStyle" TargetType="global:SliceControl">
            <Setter Property="StackDirection" Value="Vertical" />
            <Setter Property="ElementCount" Value="5" />
            <Setter Property="SliceMode" Value="0" />
            <Setter Property="DefaultIndex" Value="0" />
            <Setter Property="HoverIndex" Value="3" />
            <Setter Property="PressedIndex" Value="2" />
            <Setter Property="HoverTransition" Value="False" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Assets/Universal/Call Screen/background_hires.png" RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Image
                x:Name="Logo"
                Width="169"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Source="Assets/Universal/Branding/logo-call-big.png" />
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Image
                    x:Name="PartnerAvatar"
                    Height="160"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Profile Pictures/thegamingkart.jpg'}" />
                <TextBlock
                    x:Name="PartnerDisplayName"
                    Margin="0,18,0,5"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="thegamingkart"
                    TextAlignment="Center" />
                <TextBlock
                    FontSize="11"
                    Foreground="White"
                    Text="calling"
                    TextAlignment="Center" />
                <global:SliceControl
                    Margin="0,50"
                    VerticalAlignment="Bottom"
                    AnimationFps="30"
                    DefaultIndex="0"
                    ElementCount="10"
                    HoverIndex="1"
                    IsAnimation="True"
                    SliceMode="0"
                    Source="Assets/Universal/Call Screen/connection_anim.png"
                    StackDirection="Vertical" />
                <Image
                    x:Name="MyAvatar"
                    Height="160"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Profile Pictures/sensei_wu.jpg'}" />
            </StackPanel>
        </Grid>

        <Grid
            x:Name="ActionBar"
            Grid.Row="1"
            Margin="0,0,0,16"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <!--
                    You might be wondering why Column 1 is 156px and Column 2 is 164px,
                    and why both aren't 160px for an equally aligned UI. The answer to this
                    question is: Ask the Skype designers, it's their fault. If I fixed this
                    visual bug, it wouldn't be accurate, and this is why the columns are
                    going to remain misaligned.
                -->
                <ColumnDefinition Width="156" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="164" />
            </Grid.ColumnDefinitions>
            <global:SliceControl
                x:Name="ActionBarContainer"
                Grid.ColumnSpan="3"
                BottomHeight="33"
                SliceMode="1"
                Source="Assets/Universal/Call Screen/pill.png"
                TopHeight="3" />
            <StackPanel
                Grid.Column="0"
                Margin="24,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_sidebar_expand.png" Style="{StaticResource ActionButtonStyle}" />
                <global:SliceControl
                    Margin="8,0,0,0"
                    Source="Assets/Universal/Call Screen/btn_chat_inactive.png"
                    Style="{StaticResource ActionButtonStyle}" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <global:SliceControl
                    Margin="4,0"
                    Source="Assets/Universal/Call Screen/btn_mic.png"
                    Style="{StaticResource ActionButtonStyle}" />
                <global:SliceControl
                    Margin="4,0"
                    Source="Assets/Universal/Call Screen/btn_dialpad.png"
                    Style="{StaticResource ActionButtonStyle}" />
                <global:SliceControl
                    Margin="4,0"
                    Source="Assets/Universal/Call Screen/btn_add.png"
                    Style="{StaticResource ActionButtonStyle}" />
                <global:SliceControl
                    Margin="4,0"
                    MouseLeftButtonUp="OnHangUp"
                    Source="Assets/Universal/Call Screen/btn_hangup.png"
                    Style="{StaticResource ActionButtonStyle}" />
            </StackPanel>
            <StackPanel
                Grid.Column="2"
                Margin="0,0,24,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <global:SliceControl
                    Margin="0,0,8,0"
                    Source="Assets/Universal/Call Screen/btn_connection_4.png"
                    Style="{StaticResource ActionButtonStyle}" />
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_screen_expand.png" Style="{StaticResource ActionButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
