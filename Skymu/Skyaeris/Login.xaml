<Window x:Class="Skymu.Skyaeris.Login"
        FontFamily="Tahoma" 
        FontSize="11"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Skymu.Converters" 
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:global="clr-namespace:Skymu"
        Style="{StaticResource Window}" 
        xmlns:properties="clr-namespace:Skymu.Properties" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d" 
        Title="{Binding [sMAINMENU_SKYPE]}" 
        Closing="Login_Closing"
        Height="429" Width="526"
        ResizeMode="NoResize" 
        Loaded="Login_Loaded"
        WindowStartupLocation="CenterScreen"
        DataContext="{StaticResource Lang}">
    <Window.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator"/>
        <Style x:Key="HoverUnderlineHyperlink" TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="{StaticResource SkBlue}"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='backgrounds/LoginBackground.png'}" Stretch="Fill"/>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="MenuBarRow" Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.Row="0" Fill="{StaticResource SkBlue}"/> <!-- placeholder for menu bar so designer donesnt mess up -->
        <Grid Grid.Row="1">
            <Image x:Name="BackgroundImg" Height="371" Width="510" Stretch="Fill"/>
            <Image RenderOptions.BitmapScalingMode="HighQuality" x:Name="throbber" Source="Assets/Universal/Animations/loading-throbber.png" Width="128" Height="128" Margin="0,0,0,48" RenderTransformOrigin="0.50785,0.5001" Visibility="Collapsed">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:2.133333" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="header" Text="{Binding [sF_LOGIN_WELCOME]}" Foreground="{StaticResource SkBlue}" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="0" VerticalAlignment="Bottom" FontFamily="Arial" FontWeight="Bold" FontSize="20"/>
                <Grid x:Name="LoginControls" Grid.Column="1" Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="71"/>
                    </Grid.RowDefinitions>
                    <StackPanel Width="240" Grid.Row="0">
                        <!-- Protocol box -->
                        <TextBlock x:Name="protocolText" Text="Messaging service" Margin="0,10,0,4" FontWeight="Normal"/>
                        <ComboBox Padding="6,3" x:Name="comboProtocolBox" Height="21" Margin="0,0,0,6" IsEditable="False" Width="240" SelectionChanged="ProtocolSelectionChanged"/>

                        <!-- Username box -->
                        <TextBlock x:Name="SkypeName" Text="{Binding [sF_USERENTRY_LABEL_USERNAME]}" Margin="0,0,0,4" FontWeight="Normal"/>
                        <TextBox x:Name="usernameBox" Margin="0,0,0,6" Height="21" Width="240"/>

                        <!-- Password box -->
                        <TextBlock x:Name="Password" FontWeight="Normal" Margin="0,0,0,4" Text="{Binding [sF_USERENTRY_LABEL_PASSWORD]}"/>
                        <PasswordBox x:Name="passwordTokenBox" Margin="0,0,0,7" Height="21" Width="240"/>
                        <TextBlock x:Name="forgotPasswordLink" Margin="0,0,0,0" FontWeight="Normal" Height="28">
				   <Hyperlink Style="{StaticResource HoverUnderlineHyperlink}" NavigateUri="#" RequestNavigate="Hyperlink_RequestNavigate">
					  <Run Text="Unable to login? Ask for help here!"/>
				   </Hyperlink>
                        </TextBlock>

                        <!-- Sign-in button -->


                    </StackPanel>
                    <global:SliceControl
                        x:Name="LoginButton"
                        Grid.Row="1"
                        Cursor="Hand" 
                        Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Login/pill.png'}"
                        ElementCount="5" 
                        StackDirection="Vertical" 
                        DefaultIndex="0" 
                        DisabledIndex="0" 
                        IsEnabled="False"
                        HoverIndex="1" 
                        LeftWidth="15"
                        Margin="0,0,0,20"
                        RightWidth="15" 
                        PressedIndex="4"
                        Width="240"
                        Text="{Binding [sZAPBUTTON_SIGNIN]}"
                        TextWeight="Bold"
                        TextFont="Tahoma"
                        TextSize="11"
                        TextColor="#FF393A48"
                        TextHorizontalAlignment="Center"/>
                    <!-- Footer panel -->
                    <Border x:Name="footerPanel" Grid.Row="3" Height="55" Width="270" Background="#FFE5F7FD" CornerRadius="5" VerticalAlignment="Top">
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="15,0">
                            <CheckBox x:Name="SaveCredentials" Content="{Binding [sF_USERENTRY_CB_STOREPASSWORD]}" IsChecked="True" FontFamily="Tahoma" FontSize="11" Height="16" Padding="5,0,0,0" Margin="0,0,0,5"/>
                            <CheckBox x:Name="StartOnWinStart" Content="{Binding [sF_USERENTRY_CB_START_SKYPE]}" FontFamily="Tahoma" Padding="5,0,0,0" IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=StartOnStartup, Mode=TwoWay}" FontSize="11" Height="16"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>