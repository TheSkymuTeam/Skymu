<Page x:Class="Skymu.Skyaeris.Call"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:global="clr-namespace:Skymu"
      xmlns:converters="clr-namespace:Skymu.Converters"
      mc:Ignorable="d"
      Title="Page1" Width="1100" Height="700" >
    <Page.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator"/>
    </Page.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Assets/Universal/Call Screen/background.png"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Image Width="205" Source="Assets/Universal/Call Screen/logo_big.png" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                <Image Height="160" Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Profile Pictures/profile_anonymous.png'}" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" />
                <global:SliceControl Source="Assets/Universal/Call Screen/connection_anim.png" 
                                 StackDirection="Vertical"
                                 AnimationFps="30"
                                 ElementCount="10"
                                 IsAnimation="True"
                                 DefaultIndex="0"
                                 HoverIndex="1" 
                                 SliceMode="0"
                                 VerticalAlignment="Bottom"
                                 Margin="0,50"/>
                <Image Height="160"  Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Profile Pictures/profile_anonymous.png'}" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" x:Name="actionbar" VerticalAlignment="Bottom" MinWidth="600" HorizontalAlignment="Center" Margin="0,0,0,10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <global:SliceControl Grid.ColumnSpan="3" Source="Assets/Universal/Call Screen/pill.png" />
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_sidebar_expand.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_chat_active.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="5,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_mic.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_dialpad.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_add.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_hangup.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_connection_4.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"/>
                <global:SliceControl Source="Assets/Universal/Call Screen/btn_screen_expand.png" 
                                 StackDirection="Vertical"
                                 ElementCount="5"
                                 SliceMode="0"       
                                 DefaultIndex="0"
                                 HoverIndex="3"
                                 PressedIndex="2"
                                 Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
