                                                        HorizontalScrollBarVisibility="Disabled"
                                                        VerticalScrollBarVisibility="Visible">
                                                        <ScrollViewer.Resources>
                                                            <Style TargetType="ScrollBar">
                                                                <Setter Property="Width" Value="8" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ScrollBar">
                                                                            <Grid
                                                                                Width="8"
                                                                                HorizontalAlignment="Right"
                                                                                Background="Transparent">
                                                                                <Track Name="PART_Track" IsDirectionReversed="True">
                                                                                    <Track.Thumb>
                                                                                        <Thumb Width="6" HorizontalAlignment="Center">
                                                                                            <Thumb.Template>
                                                                                                <ControlTemplate TargetType="Thumb">
                                                                                                    <Border
                                                                                                        Width="6"
                                                                                                        HorizontalAlignment="Center"
                                                                                                        Background="White"
                                                                                                        CornerRadius="3"
                                                                                                        Opacity="0.9" />
                                                                                                </ControlTemplate>
                                                                                            </Thumb.Template>
                                                                                        </Thumb>
                                                                                    </Track.Thumb>
                                                                                </Track>
                                                                            </Grid>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ScrollViewer.Resources>
                                                        <WrapPanel x:Name="EmojiWrapPanel" Orientation="Horizontal" />
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                            <StackPanel
                                                x:Name="TypingIndicator"
                                                Margin="0,0,7,0"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="Collapsed">
                                                <global:SliceControl
                                                    x:Name="TypingIndicatorIcon"
                                                    Width="23"
                                                    AnimationFps="30"
                                                    DefaultIndex="0"
                                                    ElementCount="37"
                                                    HoverIndex="-1"
                                                    IsAnimation="True"
                                                    PressedIndex="-1"
                                                    SliceMode="0"
                                                    Source="Assets/Universal/Chat/pencil-write.png"
                                                    StackDirection="Vertical" />
                                                <TextBlock
                                                    x:Name="TypingIndicatorText"
                                                    Margin="3,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="#666666" />
                                            </StackPanel>
                                        </Grid>
                                        <Border
                                            MinHeight="35"
                                            Background="White"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1,0,1,1"
                                            CornerRadius="0,0,4,4">
                                            <RichTextBox
                                                x:Name="MessageTextBox"
                                                Padding="4,5,4,4"
                                                AcceptsReturn="True"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontFamily="Tahoma"
                                                FontSize="11"
                                                GotKeyboardFocus="MessageTextBox_Focused"
                                                LostKeyboardFocus="MessageTextBox_Unfocused"
                                                PreviewKeyDown="MessageTextBox_PreviewKeyDown"
                                                SnapsToDevicePixels="True"
                                                TextChanged="MessageTextBox_TextChanged"
                                                UseLayoutRounding="True"
                                                VerticalScrollBarVisibility="Auto">
                                                <RichTextBox.Document>
                                                    <FlowDocument>
                                                        <Paragraph Margin="0" />
                                                    </FlowDocument>
                                                </RichTextBox.Document>
                                            </RichTextBox>
                                        </Border>
                                    </StackPanel>
                                    <global:SliceControl
                                        x:Name="SendMsgButton"
                                        Grid.Column="2"
                                        Width="Auto"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        DefaultIndex="0"
                                        ElementCount="5"
                                        Focusable="False"
                                        HoverIndex="1"
                                        IsEnabled="False"
                                        LeftWidth="22"
                                        MouseLeftButtonUp="OnMsgSendClickButton"
                                        PressedIndex="2"
                                        RightWidth="22"
                                        Source="Assets/Universal/Chat/msg-send-button-full.png"
                                        StackDirection="Vertical"
                                        Text="{Binding Source={StaticResource Lang}, Path=[sZAPBUTTON_SENDMESSAGE]}"
                                        TextColor="White"
                                        TextFont="Arial"
                                        TextLeftMargin="26"
                                        TextSize="13"
                                        TextWeight="Bold" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>