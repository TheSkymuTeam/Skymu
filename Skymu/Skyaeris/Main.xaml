<Window
    x:Class="Skymu.Skyaeris.Main"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
    xmlns:global="clr-namespace:Skymu"
    xmlns:local="clr-namespace:Skymu.Skyaeris"
    xmlns:plugin="clr-namespace:MiddleMan;assembly=MiddleMan"
    xmlns:properties="clr-namespace:Skymu.Properties"
    Title="Skymu"
    Width="1448"
    Height="856"
    MinWidth="800"
    MinHeight="450"
    Activated="Window_Activated"
    AllowsTransparency="True"
    Background="#8cbeff"
    Closing="Main_Closing"
    DataContext="{StaticResource Lang}"
    Deactivated="Window_Deactivated"
    FontFamily="Tahoma"
    FontSize="11"
    ResizeMode="CanResize"
    StateChanged="Window_StateChanged"
    Style="{StaticResource Window}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <Style x:Key="TextBlockViewerStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="420" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <converters:ByteArrayToImageSourceConverter x:Key="ProfilePictureConverter" />
        <converters:MsgByteArrayToImageConverter x:Key="MsgByteArrayToImageConverter" />
        <converters:SenderToColorConverter x:Key="SenderToColorConverter" />
        <converters:NullDependentVisibilityConverter x:Key="NullDependentVisibilityConverter" />
        <converters:NullDependentBoolean x:Key="NullDependentBoolean" />
        <converters:StatusToTextConverter x:Key="StatIntToText" />
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <converters:ForwardedChecker x:Key="ForwardedChecker" />
        <converters:ReplyBodyConverter x:Key="ReplyBodyConverter" />
        <converters:PresenceStatusConverter x:Key="PresenceStatusConverter" />
        <converters:ChannelTypeConverter x:Key="ChannelTypeConverter" />
        <converters:TextStatusConverter x:Key="TextStatusConverter" />
        <converters:MsgIDMultiToVisibilityConverter x:Key="IDToVisibilityConverter" />
        <converters:PreviewVisibilityConverter x:Key="PreviewVisibilityConverter" />
        <converters:CompactConversationTypeConverter x:Key="CompactConversationTypeConverter" />
        <converters:FormatFullTextConverter x:Key="FormatFullTextConverter" ViewerStyle="{StaticResource TextBlockViewerStyle}" />
        <Style x:Key="WindowButtonStyle" TargetType="global:SliceControl">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="-1,0,0,0" />
            <Setter Property="HoverTransition" Value="False" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
            <Setter Property="SliceMode" Value="0" />
            <Setter Property="ElementCount" Value="4" />
            <Setter Property="StackDirection" Value="Vertical" />
            <Setter Property="DefaultIndex" Value="0" />
            <Setter Property="HoverIndex" Value="2" />
            <Setter Property="PressedIndex" Value="3" />
        </Style>
        <Style x:Key="LongIconStyle" TargetType="Image">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Width" Value="36" />
        </Style>
        <!--  CONTACT ITEM TEMPLATE START  -->
        <!--  Shared style for both targeted templates  -->
        <Style x:Key="ContactUsernameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ContactStatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <!--  User template  -->
        <DataTemplate DataType="{x:Type plugin:DirectMessage}">
            <Grid Height="32" Margin="2,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="14" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Profile picture  -->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0,0,0">
                    <Border Background="Transparent" CornerRadius="0">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                Opacity="0.50"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                        <Grid>
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding Source="user" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border
                                BorderBrush="#80BBBBBB"
                                BorderThickness="1"
                                CornerRadius="0" />
                        </Grid>
                    </Border>
                </Grid>
                <global:SliceControl
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="14"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    DefaultIndex="{Binding Partner.PresenceStatus, Converter={StaticResource PresenceStatusConverter}}"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon Bitmap/skype-status-small.png"
                    StackDirection="Horizontal" />
                <!--  Name + status text  -->
                <TextBlock
                    x:Name="usernameText"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Style="{StaticResource ContactUsernameStyle}"
                    Text="{Binding DisplayName}" />
                <TextBlock
                    x:Name="statusText"
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,1,0,0"
                    Style="{StaticResource ContactStatusStyle}"
                    Text="{Binding Partner.Status, TargetNullValue=''}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White" />
                    <Setter TargetName="statusText" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!--  Group template  -->
        <DataTemplate DataType="{x:Type plugin:Group}">
            <Grid Height="32" Margin="2,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="14" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Profile picture  -->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0,0,0">
                    <Border Background="Transparent" CornerRadius="0">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                Opacity="0.50"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                        <Grid>
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding Source="group" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border
                                BorderBrush="#80BBBBBB"
                                BorderThickness="1"
                                CornerRadius="0" />
                        </Grid>
                    </Border>
                </Grid>
                <global:SliceControl
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="14"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    DefaultIndex="21"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon Bitmap/skype-status-small.png"
                    StackDirection="Horizontal" />
                <!--  Name + member count  -->
                <TextBlock
                    x:Name="usernameText"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Style="{StaticResource ContactUsernameStyle}"
                    Text="{Binding DisplayName}" />
                <TextBlock
                    x:Name="statusText"
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,1,0,0"
                    Style="{StaticResource ContactStatusStyle}"
                    Text="{Binding Members.Length, StringFormat={}{0} members}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White" />
                    <Setter TargetName="statusText" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!--  Server template  -->
        <HierarchicalDataTemplate DataType="{x:Type plugin:Server}" ItemsSource="{Binding GroupedChannels}">
            <HierarchicalDataTemplate.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type global:CategoryHeaderItem}">
                                <Border
                                    Margin="0"
                                    Padding="8,4"
                                    Background="#F0F0F0">
                                    <TextBlock
                                        FontFamily="Tahoma"
                                        FontSize="11"
                                        Foreground="#000000"
                                        Text="{Binding CategoryName}" />
                                </Border>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type plugin:ServerChannel}">
                                <Grid Height="22" Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <global:SliceControl
                                        Grid.Column="0"
                                        Width="14"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left"
                                        DefaultIndex="{Binding ChannelType, Converter={StaticResource ChannelTypeConverter}}"
                                        ElementCount="11"
                                        HoverIndex="-1"
                                        PressedIndex="-1"
                                        SliceMode="0"
                                        Source="Assets/Universal/Icon Bitmap/skype-channel.png"
                                        StackDirection="Horizontal" />
                                    <TextBlock
                                        x:Name="channelText"
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="Black"
                                        Style="{StaticResource ContactStatusStyle}"
                                        Text="{Binding DisplayName}" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter TargetName="channelText" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
            <Grid Height="32" Margin="2,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="14" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Profile picture  -->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0,0,0">
                    <Border Background="Transparent" CornerRadius="0">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                Opacity="0.50"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                        <Grid>
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding Source="group" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border
                                BorderBrush="#80BBBBBB"
                                BorderThickness="1"
                                CornerRadius="0" />
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock
                    x:Name="usernameText"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Style="{StaticResource ContactUsernameStyle}"
                    Text="{Binding DisplayName}" />
                <TextBlock
                    x:Name="statusText"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="10,1,0,0"
                    Style="{StaticResource ContactStatusStyle}"
                    Text="{Binding MemberCount, StringFormat={}{0} members}" />
                <ToggleButton
                    Grid.RowSpan="3"
                    Grid.Column="2"
                    Width="16"
                    Height="16"
                    Margin="0,0,4,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}, Mode=TwoWay}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid Width="12" Height="12">
                                <Image
                                    Width="12"
                                    Height="12"
                                    Source="Assets/Universal/Sidebar/collapse-toggle-background.png" />
                                <Image
                                    x:Name="ToggleImage"
                                    Width="12"
                                    Height="12"
                                    RenderTransformOrigin="0.5,0.5"
                                    Source="Assets/Universal/Sidebar/collapse-toggle-arrow.png">
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ToggleImage" Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="90" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White" />
                    <Setter TargetName="statusText" Property="Foreground" Value="White" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
        <!--  CONTACT ITEM TEMPLATE END  -->
        <!--  COMPACT RECENTS TEMPLATES START  -->
        <DataTemplate x:Key="DateHeaderTemplate" DataType="{x:Type global:DateHeaderItem}">
            <Border
                Margin="0"
                Padding="8,4"
                Background="#F0F0F0">
                <TextBlock
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="#000000"
                    Text="{Binding DateText}" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="CompactDirectMessageTemplate" DataType="{x:Type plugin:DirectMessage}">
            <Grid Height="22" Margin="8,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <global:SliceControl
                    Grid.Column="0"
                    Width="14"
                    Height="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    DefaultIndex="{Binding Partner.PresenceStatus, Converter={StaticResource PresenceStatusConverter}}"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon Bitmap/skype-status-small.png"
                    StackDirection="Horizontal" />
                <TextBlock
                    x:Name="compactName"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Text="{Binding DisplayName}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="compactName" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <DataTemplate x:Key="CompactGroupTemplate" DataType="{x:Type plugin:Group}">
            <Grid Height="22" Margin="8,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <global:SliceControl
                    Grid.Column="0"
                    Width="14"
                    Height="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    DefaultIndex="21"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon Bitmap/skype-status-small.png"
                    StackDirection="Horizontal" />
                <TextBlock
                    x:Name="compactGroupName"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Text="{Binding DisplayName}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="compactGroupName" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!--  COMPACT RECENTS TEMPLATES END  -->


        <!--  SERVER CHANNEL TEMPLATES END  -->
        <!--  CONVERSATION ITEM TEMPLATES START  -->
        <!--  MessageItem Template  -->
        <DataTemplate DataType="{x:Type plugin:Message}">
            <Grid x:Name="ConversationGrid" Margin="0,9.5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="98" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <!--  Reply header  -->
                <VirtualizingStackPanel
                    Grid.Row="0"
                    Grid.ColumnSpan="4"
                    Margin="114,0,0,2"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Visibility="{Binding ParentMessage, Converter={StaticResource NullDependentVisibilityConverter}}">
                    <Image
                        Width="12"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True"
                        Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Chat/reply-arrow.png'}" />
                    <TextBlock
                        Width="400"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Foreground="#999999"
                        LineHeight="1"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Replying to {0} - &quot;{1}&quot;">
                                <Binding Path="ParentMessage.Sender.DisplayName" />
                                <Binding Converter="{StaticResource ReplyBodyConverter}" Path="ParentMessage.Text" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </VirtualizingStackPanel>
                <!--  Sender name  -->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="-1000,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="Tahoma"
                    FontSize="11">
                    <TextBlock.Foreground>
                        <MultiBinding Converter="{StaticResource SenderToColorConverter}">
                            <Binding Path="Sender.Identifier" />
                            <Binding Path="IsForwarded" />
                        </MultiBinding>
                    </TextBlock.Foreground>
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ForwardedChecker}">
                            <Binding Path="Sender.DisplayName" />
                            <Binding Path="IsForwarded" />
                        </MultiBinding>
                    </TextBlock.Text>
                    <TextBlock.Visibility>
                        <MultiBinding Converter="{StaticResource IDToVisibilityConverter}">
                            <Binding Path="PreviousMessageIdentifier" />
                            <Binding Path="Sender.Identifier" />
                        </MultiBinding>
                    </TextBlock.Visibility>
                </TextBlock>
                <!--  Message body + attachment  -->
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="2"
                    Orientation="Vertical">
                    <ContentControl Content="{Binding Text, Converter={StaticResource FormatFullTextConverter}}" Visibility="{Binding Text, Converter={StaticResource NullDependentVisibilityConverter}}" />
                    <Image
                        MaxWidth="300"
                        MaxHeight="300"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="{Binding Attachments[0].File, Converter={StaticResource MsgByteArrayToImageConverter}}"
                        Stretch="Uniform"
                        Visibility="{Binding Attachments, Converter={StaticResource NullDependentVisibilityConverter}}" />
                </StackPanel>
                <!--  Timestamp  -->
                <Grid
                    Grid.Row="1"
                    Grid.Column="3"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    <TextBlock
                        FontFamily="Tahoma"
                        FontSize="11"
                        Foreground="#999999"
                        Text="{Binding Time, StringFormat=h:mm tt}"
                        Visibility="{Binding Identifier, Converter={StaticResource PreviewVisibilityConverter}, ConverterParameter=invert}" />
                    <global:SliceControl
                        Width="10"
                        Height="10"
                        AnimationFps="60"
                        DefaultIndex="0"
                        ElementCount="72"
                        IsAnimation="True"
                        SliceMode="0"
                        Source="Assets/Universal/Chat/loading.png"
                        StackDirection="Vertical"
                        Visibility="{Binding Identifier, Converter={StaticResource PreviewVisibilityConverter}}" />
                </Grid>
            </Grid>
        </DataTemplate>
        <!--  CallStartedItem Template  -->
        <DataTemplate DataType="{x:Type plugin:CallStartedNotice}">
            <Grid Margin="0,9.5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="114" />
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="1"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="#999999"
                    Text="{Binding StartedBy, StringFormat='Call started by: {0}'}" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="#999999"
                    Text="{Binding Time, StringFormat=h:mm tt}" />
            </Grid>
        </DataTemplate>
        <!--  CallEndedItem Template  -->
        <DataTemplate DataType="{x:Type plugin:CallEndedNotice}">
            <Grid Margin="0,9.5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="114" />
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="1"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="#999999"
                    Text="{Binding Duration, StringFormat='Call ended, duration: {0}'}" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="#999999"
                    Text="{Binding Time, StringFormat=h:mm tt}" />
            </Grid>
        </DataTemplate>
        <!--  CONVERSATION ITEM TEMPLATE END  -->
        <Style x:Key="NoInsetListBox" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer
                            x:Name="ScrollViewer"
                            Margin="0"
                            Padding="0"
                            VerticalContentAlignment="Bottom"
                            CanContentScroll="True"
                            Focusable="false">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="FrameArea">
        <Grid
            x:Name="TitleBar"
            Height="30"
            VerticalAlignment="Top">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="#FF6B9DE0" />
                    <GradientStop Offset="0.0634" Color="#f0f6fe" />
                    <GradientStop Offset="0.0667" Color="#d2e5fe" />
                    <GradientStop Offset="1" Color="#8cbeff" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="121" />
            </Grid.ColumnDefinitions>
            <StackPanel
                x:Name="CaptionButtons"
                Grid.Column="1"
                Margin="0,0,5,0"
                Orientation="Horizontal">
                <global:SliceControl
                    x:Name="split"
                    Width="26"
                    MouseEnter="TitleButton_MouseEnter"
                    MouseLeave="TitleButton_MouseLeave"
