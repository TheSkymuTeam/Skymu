<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Base Colors  -->
    <SolidColorBrush x:Key="DarkBlueBrush" Color="#1d3a55" />
    <SolidColorBrush x:Key="WhiteBrush" Color="#f4f4f4" />

    <!--  ================= ACTIVE =================  -->

    <!--  Titlebar  -->
    <LinearGradientBrush x:Key="Active.TitlebarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF6B9DE0" />
        <GradientStop Offset="0.0634" Color="#f0f6fe" />
        <GradientStop Offset="0.0667" Color="#d2e5fe" />
        <GradientStop Offset="1.0" Color="#8cbeff" />
    </LinearGradientBrush>

    <!--  Window  -->
    <LinearGradientBrush x:Key="Active.WindowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#c5deff" />
        <GradientStop Offset="1.0" Color="#8cbeff" />
    </LinearGradientBrush>

    <!--  MenuBar  -->
    <SolidColorBrush x:Key="Active.MenuBarBrush" Color="#c6dfff" />

    <!--  Standard  -->
    <SolidColorBrush x:Key="Active.StandardBrush" Color="#8cbeff" />

    <!--  ================= INACTIVE =================  -->

    <!--  Titlebar  -->
    <LinearGradientBrush x:Key="Inactive.TitlebarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#f0f0f0" />
        <GradientStop Offset="0.0634" Color="#f8f8f8" />
        <GradientStop Offset="0.0667" Color="#f4f4f4" />
        <GradientStop Offset="1.0" Color="#d7d7d7" />
    </LinearGradientBrush>

    <!--  Window  -->
    <LinearGradientBrush x:Key="Inactive.WindowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#ebecf0" />
        <GradientStop Offset="1.0" Color="#d8dae1" />
    </LinearGradientBrush>

    <!--  MenuBar  -->
    <SolidColorBrush x:Key="Inactive.MenuBarBrush" Color="#f0edec" />

    <!--  Standard  -->
    <SolidColorBrush x:Key="Inactive.StandardBrush" Color="#d8dae1" />

</ResourceDictionary>