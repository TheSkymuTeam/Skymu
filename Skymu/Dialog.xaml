<Window x:Class="Skymu.Dialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fallback Dialog" ResizeMode="NoResize" WindowStyle="SingleBorderWindow" Height="235" Width="373" Icon="/Skymu;component/UniversalResources/Icon/Skype.ico">
    <Grid>
        <Image x:Name="DialogImage" Height="96" Width="48" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="11,10,0,78" Panel.ZIndex="2"/>
        <Grid VerticalAlignment="Top" Height="45">
            <Border Name="GradientTop"  BorderThickness="0,0,0,1" BorderBrush="#DADADA"  HorizontalAlignment="Stretch">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F2F2F2" Offset="0" />
                        <GradientStop Color="#E6E6E6" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

            </Border>
            <TextBlock Height="23" x:Name="header" Text="DEVELOPER: Fallback Dialog" Margin="70,3,0,0" FontFamily="Arial" FontWeight="Bold" Foreground="#333333" FontSize="13"/>
        </Grid>
        <TextBlock LineHeight="16" TextWrapping="Wrap" Name="sub" Text="Dialog window called but null or invalid dialog type&#x0a;specified. This is a fallback dialog specified in XAML." Margin="77,62,10,50" FontFamily="Tahoma" FontSize="11"/>
        <Grid VerticalAlignment="Bottom" Height="44" RenderTransformOrigin="0.531,0.545">
            <Border Name="GradientBottom"  BorderThickness="0,1,0,0" BorderBrush="#DADADA"  HorizontalAlignment="Stretch">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F2F2F2" Offset="0" />
                        <GradientStop Color="#E6E6E6" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>


            </Border>
            <Grid x:Name="BottomControlsGrid">
                <TextBox x:Name="DialogTextBox" Visibility="Hidden"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"  TextAlignment="Center" TextWrapping="Wrap" Height="23" VerticalAlignment="Center" HorizontalAlignment="Left" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display" FontFamily="Tahoma" FontSize="11"  TextOptions.TextHintingMode="Fixed" Margin="10,0,0,0" Width="250"/>
                <Button Content="Exit" Click="bLClick" x:Name="buttonLeft" Width="73" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,95,0" Height="23" FontFamily="Tahoma" FontSize="11" />
                <Button Content="Return" Click="bRClick" IsDefault="True" x:Name="buttonRight" Width="73" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Height="23"  FontSize="11" FontFamily="Tahoma"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
