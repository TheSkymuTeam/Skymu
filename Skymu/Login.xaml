<Window x:Class="Skymu.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Skymu"
        Title="Skype" Closing="Login_Closing" Height="429" Width="516" ResizeMode="NoResize" WindowStyle="SingleBorderWindow" Loaded="Login_Loaded" Icon="/Skymu;component/UniversalResources/Icon/Skype.ico">
    <Window.Resources>
        <Style x:Key="HoverUnderlineHyperlink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource Sk5Link}" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Image x:Name="BackgroundImg" Height="371" Width="510" Stretch="Fill" />

        <TextBlock x:Name="header" Text="Welcome to Skype." Foreground="{StaticResource SkBlue}"
                   Height="32" HorizontalAlignment="Center" Margin="-1,44,0,0"
                   VerticalAlignment="Top" FontFamily="Arial" FontWeight="Bold" FontSize="20" />

        <TextBlock x:Name="skypenameText" Text="Username" Height="28" HorizontalAlignment="Left"
                   Margin="135,140,0,0" VerticalAlignment="Top"
                   FontFamily="Tahoma" FontSize="11" FontWeight="Normal" />

        <TextBlock x:Name="protocolText" Text="Messaging service" Height="28" HorizontalAlignment="Left"
                   Margin="135,96,0,0" VerticalAlignment="Top"
                   FontFamily="Tahoma" FontSize="11" FontWeight="Normal" />

        <TextBlock x:Name="forgotPasswordLink" FontFamily="Tahoma" FontSize="11" FontWeight="Normal"
                   Height="28" HorizontalAlignment="Left" Margin="135,225,0,0"
                   VerticalAlignment="Top">
            <Hyperlink Style="{StaticResource HoverUnderlineHyperlink}"
                       NavigateUri="#" RequestNavigate="Hyperlink_RequestNavigate">
                Unable to login?
            </Hyperlink>
        </TextBlock>

        <TextBlock x:Name="passwordText" FontFamily="Tahoma" FontSize="11" FontWeight="Normal"
                   Height="28" HorizontalAlignment="Left" Margin="135,183,0,0"
                   Text="Password" VerticalAlignment="Top" />
        <ComboBox Name="comboProtocolBox" TextOptions.TextRenderingMode="ClearType" IsEditable="False" TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20" HorizontalAlignment="Left" Margin="135,112,0,0" VerticalAlignment="Top" Width="240" FontFamily="Tahoma" FontSize="11" SelectionChanged="ProtocolSelectionChanged" />
        <TextBox Name="usernameBox" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20" HorizontalAlignment="Left" Margin="135,155,0,0" VerticalAlignment="Top" Width="240" FontFamily="Tahoma" FontSize="11"/>
        <PasswordBox Name="passwordTokenBox" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20" HorizontalAlignment="Left" Margin="135,198,0,0" VerticalAlignment="Top" Width="240" FontFamily="Tahoma" FontSize="11"/>
        <Canvas>
            <Grid Name="BBuilderGrid" Margin="126,259,128,87" SnapsToDevicePixels="True" Canvas.Left="9" Canvas.Top="-4" Height="25" Width="240">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Left: native size -->
                    <ColumnDefinition Width="*"/>
                    <!-- Middle: stretch to fill -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Right: native size -->
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="signInText" Grid.Column="1" Height="13" HorizontalAlignment="Center" Margin="-1,6,0,0" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Text="Sign in" VerticalAlignment="Top" Panel.ZIndex="1" FontFamily="Tahoma" FontWeight="Bold" FontSize="11" Foreground="#FF393A48" />
                <Image Opacity = "0.4" Name="lBI" Grid.Column="0"/>
                <Image Opacity = "0.4" Name="mBI" Grid.Column="1" Stretch="Fill" VerticalAlignment="Top"/>
                <Image Opacity = "0.4" Name="rBI" Grid.Column="2"/>
            </Grid>
        </Canvas>
        <Canvas>
            <Rectangle x:Name="footerPanel" Canvas.Left="121" Canvas.Bottom="16" Height="55" Stroke="{x:Null}" Width="269" Fill="#FFE5F7FD" RadiusX="5" RadiusY="5" UseLayoutRounding="False" />
            <CheckBox x:Name="autoSignInCheck" Canvas.Left="135" Canvas.Top="310" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Content="Sign me in when Skype starts" Height="16" IsChecked="True" FontFamily="Tahoma" FontSize="11" />
            <CheckBox x:Name="startupSeanKypeCheck" Canvas.Left="135" Canvas.Top="331" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Content="Start Skype when computer starts" Height="16" FontFamily="Tahoma" FontSize="11" />
        </Canvas>
    </Grid>
</Window>
