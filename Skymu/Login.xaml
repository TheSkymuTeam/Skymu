<Window x:Class="Skymu.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Skymu"
        Title="Skype" Closing="Login_Closing" Height="429" Width="526" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow" Loaded="Login_Loaded"
        WindowStartupLocation="CenterScreen"
        Icon="/Skymu;component/UniversalResources/Icon/Skype.ico">
    <Window.Resources>
        <Style x:Key="HoverUnderlineHyperlink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource Sk5Link}" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/ResourcesLight/Backgrounds/loginBackground.png" Stretch="Fill"/>
    </Window.Background>
    <Grid>
        <Image x:Name="BackgroundImg" Height="371" Width="510" Stretch="Fill" />

        <TextBlock x:Name="header" Text="Welcome to Skype." Foreground="{StaticResource SkBlue}"
                   Height="32" HorizontalAlignment="Center" Margin="0,44,0,0"
                   VerticalAlignment="Top" FontFamily="Arial" FontWeight="Bold" FontSize="20" />
        <local:SliceControl
    x:Name="throbber"
            Visibility="Collapsed"
    Grid.Column="1"
    Source="/UniversalResources/Animations/LoginCircler.png"
    ElementCount="36"
    StackDirection="Vertical"
    DefaultIndex="0"
    HoverIndex="-1"
    PressedIndex="-1"
    TextWeight="Bold"
    Slice="False"
            IsAnimation="True"
            AnimationFps="60"
    HorizontalAlignment="Center" 
            Margin="0,0,0,48"
            Width="128"/>
        <Grid x:Name="signInControls">
        <TextBlock x:Name="skypenameText" Text="Username" Height="28" HorizontalAlignment="Left"
                   Margin="136,140,0,0" VerticalAlignment="Top"
                   FontFamily="Tahoma" FontSize="11" FontWeight="Normal" />

        <TextBlock x:Name="protocolText" Text="Messaging service" Height="28" HorizontalAlignment="Left"
                   Margin="136,96,0,0" VerticalAlignment="Top"
                   FontFamily="Tahoma" FontSize="11" FontWeight="Normal" />

        <TextBlock x:Name="forgotPasswordLink" FontFamily="Tahoma" FontSize="11" FontWeight="Normal"
                   Height="28" HorizontalAlignment="Left" Margin="136,225,0,0"
                   VerticalAlignment="Top">
            <Hyperlink Style="{StaticResource HoverUnderlineHyperlink}"
                       NavigateUri="#" RequestNavigate="Hyperlink_RequestNavigate">
                Unable to login?
            </Hyperlink>
        </TextBlock>

        <TextBlock x:Name="passwordText" FontFamily="Tahoma" FontSize="11" FontWeight="Normal"
                   Height="28" HorizontalAlignment="Left" Margin="136,183,0,0"
                   Text="Password" VerticalAlignment="Top" />
        <ComboBox Name="comboProtocolBox" TextOptions.TextRenderingMode="ClearType" IsEditable="False"
                  TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20"
                  HorizontalAlignment="Center" Margin="0,112,0,0" VerticalAlignment="Top" Width="240"
                  FontFamily="Tahoma" FontSize="11" SelectionChanged="ProtocolSelectionChanged" />
        <TextBox Name="usernameBox" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display"
                 TextOptions.TextHintingMode="Fixed" Height="20" Margin="0,155,0,0" 
                 VerticalAlignment="Top" FontFamily="Tahoma" FontSize="11" Width="240" />
        <PasswordBox Name="passwordTokenBox" TextOptions.TextRenderingMode="ClearType"
                     TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20"
                      Margin="0,198,0,0" VerticalAlignment="Top" Width="240"
                     FontFamily="Tahoma" FontSize="11" />

        <Canvas IsHitTestVisible="True">
            <Grid Name="BBuilderGrid" Margin="126,259,128,87" SnapsToDevicePixels="True" Canvas.Left="9"
                  Canvas.Top="-4" Width="240">
                <TextBlock x:Name="signInText" Grid.Column="1" IsHitTestVisible="False" Height="13" HorizontalAlignment="Center"
                           Margin="-1,6,0,0" TextOptions.TextRenderingMode="ClearType"
                           TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Text="Sign in"
                           VerticalAlignment="Top" Panel.ZIndex="1" FontFamily="Tahoma" FontWeight="Bold" FontSize="11"
                           Foreground="#FF393A48" />
                <local:SliceControl
                    x:Name="LoginButton"
                    Grid.Row="0"
                    Cursor="Hand"
                    Source="/ResourcesLight/Buttons/plain.png"
                    ElementCount="5"
                    StackDirection="Vertical"
                    DefaultIndex="0"
                    DisabledIndex="2"
                    IsEnabled="False"
                    HoverIndex="1"
                    Margin="0,0,0,0"
                    PressedIndex="4"
                    Width="240" />
            </Grid>
        </Canvas>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Footer panel -->
            <Rectangle x:Name="footerPanel"
                       Grid.Row="1"
                       Height="55"
                       Width="269"
                       Fill="#FFE5F7FD"
                       RadiusX="5"
                       RadiusY="5"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- Checkboxes -->
            <StackPanel Grid.Row="1"
                        Margin="135,0,0,24"
                        VerticalAlignment="Bottom">

                <CheckBox x:Name="autoSignInCheck"
                          Content="Sign me in when Skype starts"
                          IsChecked="True"
                          FontFamily="Tahoma"
                          FontSize="11"
                          Height="16"
                          Margin="0,0,0,5"
                          TextOptions.TextRenderingMode="ClearType"
                          TextOptions.TextFormattingMode="Display"
                          TextOptions.TextHintingMode="Fixed"/>

                <CheckBox x:Name="startupSeanKypeCheck"
                          Content="Start Skype when computer starts"
                          FontFamily="Tahoma"
                          FontSize="11"
                          Height="16"
                          TextOptions.TextRenderingMode="ClearType"
                          TextOptions.TextFormattingMode="Display"
                          TextOptions.TextHintingMode="Fixed"/>
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</Window>